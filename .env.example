# ══════════════════════════════════════════════════
# Leon's Quote System — Environment Variables
# Copy this to .env in Vercel dashboard (Settings > Environment Variables)
# NEVER commit real values to GitHub
# ══════════════════════════════════════════════════

# ── Twilio (get from twilio.com/console) ──
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Supabase (get from supabase.com > Project Settings > API) ──
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Security ──
OTP_SALT=choose_a_random_long_string_here_eg_leonsvp2026

# Optional email notifications (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
MAIL_FROM=Leon Quotes <quotes@example.com>
ADMIN_NOTIFICATION_EMAIL=studio@example.com

# ── Admin phones (Leon's number — gets admin dashboard on login) ──
ADMIN_PHONE_1=+17805550000
ADMIN_PHONE_2=+15875550000
